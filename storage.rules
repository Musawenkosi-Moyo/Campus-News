rules_version = '2';

// Deploy: Firebase Console → Build → Storage → Rules, paste and Publish.
// Or: firebase deploy --only storage (if this file is wired in firebase.json).

service firebase.storage {
  match /b/{bucket}/o {
    match /news_images/{fileName} {
      allow read: if true;
      allow write: if request.auth != null
        && request.resource.size < 10 * 1024 * 1024
        && request.resource.contentType.matches('image/.*');
    }
  }
}
